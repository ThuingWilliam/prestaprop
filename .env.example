# Copia este archivo como .env y completa los valores

# Clave secreta de Flask (cambia esto en produccion)
SECRET_KEY=enterprise_secret_key_123!@#

# DB local (desarrollo)
# DATABASE_URL=postgresql://postgres:admin@localhost:5432/prestamos

# DB Neon (produccion) - pega aqui tu connection string de neon.tech
DATABASE_URL=postgresql://usuario:clave@ep-xxx.us-east-2.aws.neon.tech/prestamos?sslmode=require

# Modo debug: 'true' en local, 'false' en produccion
FLASK_DEBUG=true
